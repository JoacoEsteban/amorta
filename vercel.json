{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "bunVersion": "1.x",
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/result/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/result",
      "destination": "/index.html"
    }
  ]
}
