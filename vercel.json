{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "bunVersion": "1.x",
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/result/:path*",
      "destination": "/result/index.html"
    },
    {
      "source": "/:locale/result/:path*",
      "destination": "/:locale/result/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "permanent": true
    },
    {
      "source": "/en-US/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ]
}
